{
  "name": "kryo-monorepo",
  "private": true,
  "scripts": {
    "clean": "rimraf --glob \"packages/*/@(lib|main|test)\"",
    "lint": "eslint --config eslint.config.mjs --ext mts \"packages/*/src/**/*.mts\"",
    "format": "eslint --config eslint.config.mjs --ext mts --fix \"packages/*/src/**/*.mts\"",
    "test:build": "tsc --build test.tsconfig.json",
    "test": "yarn run test:build && node --test \"packages/*/src/test/**/*.spec.mts\""
  },
  "engines": {
    "node": ">=23.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "type": "module",
  "packageManager": "yarn@4.17.1"
}
