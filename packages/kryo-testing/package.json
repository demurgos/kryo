{
  "name": "kryo-testing",
  "version": "0.16.1",
  "description": "Helpers to test Kryo types and serializers",
  "license": "MIT",
  "keywords": [],
  "homepage": "https://demurgos.github.io/kryo",
  "repository": {
    "type": "git",
    "url": "git://github.com/demurgos/kryo.git"
  },
  "scripts": {
    "lint": "eslint \"./src/**/*.mts\"",
    "format": "eslint --fix \"./src/**/*.mts\"",
    "build": "tsc --build src/lib/tsconfig.json",
    "prepack": "yarn run build"
  },
  "engines": {
    "node": ">=18.13.0"
  },
  "dependencies": {
    "kryo": "workspace:^",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  },
  "type": "module",
  "exports": {
    ".": "./lib/index.mjs",
    "./*": "./lib/*.mjs"
  },
  "files": [
    "./lib/**/*.(mjs|map|mts)",
    "./src/lib/**/*.mts"
  ]
}
